{
  // sing-box 客户端单文件配置
  // 场景：Linux 客户端，TUN 接管流量，连接美国服务端
  // 用法：四种协议里只保留一个 "type": ... 的 proxy 出站启用，其他注释掉

  "log": {
    // 调试时可改成 "debug"
    "level": "info"
  },

  "dns": {
    "servers": [
      {
        // 本地 DNS，先用国内公共 DNS 跑通
        "tag": "local",
        "type": "udp",
        "server": "223.5.5.5"
      }
    ],
    // 默认 DNS 服务器
    "final": "local",
    // 优先 IPv4，通常更稳
    "strategy": "prefer_ipv4"
  },

  "inbounds": [
    {
      // TUN 虚拟网卡入口：把系统流量接进 sing-box
      "type": "tun",
      "tag": "tun-in",

      // TUN 网段，按官方示例使用一个最小私网段
      "address": [
        "172.19.0.1/30"
      ],

      // 自动下发到 TUN 的默认路由
      "auto_route": true,

      // Linux 推荐开启，透明代理体验更好
      "auto_redirect": true,

      // 严格路由，避免部分流量绕过
      "strict_route": true
    }
  ],

  "outbounds": [
    {
      // 当前正在使用的代理出站
      // 这里默认启用 Trojan
      "type": "trojan",
      "tag": "proxy",
      "server": "YOUR_SERVER_IP",
      "server_port": 443,
      "password": "YOUR_TROJAN_PASSWORD",
      "tls": {
        "enabled": true,

        // 你现在是直连 IP，可以先随便写一个值占位
        // 若服务端是自签证书并且客户端忽略校验，这个字段不会严格校验
        "server_name": "example.com",

        // 临时测试可用；正式环境建议改成有效证书并关闭
        "insecure": true
      }
    }

    // 如果要改用 Shadowsocks：
    // ,{
    //   "type": "shadowsocks",
    //   "tag": "proxy",
    //   "server": "YOUR_SERVER_IP",
    //   "server_port": 8388,
    //   "method": "aes-256-gcm",
    //   "password": "YOUR_SS_PASSWORD"
    // }

    // 如果要改用 VMess：
    // ,{
    //   "type": "vmess",
    //   "tag": "proxy",
    //   "server": "YOUR_SERVER_IP",
    //   "server_port": 9443,
    //   "uuid": "11111111-1111-1111-1111-111111111111",
    //   "security": "auto",
    //   "alter_id": 0,
    //   "tls": {
    //     "enabled": true,
    //     "server_name": "example.com",
    //     "insecure": true
    //   }
    // }

    // 如果要改用 VLESS：
    // ,{
    //   "type": "vless",
    //   "tag": "proxy",
    //   "server": "YOUR_SERVER_IP",
    //   "server_port": 8443,
    //   "uuid": "22222222-2222-2222-2222-222222222222",
    //   "tls": {
    //     "enabled": true,
    //     "server_name": "example.com",
    //     "insecure": true
    //   }
    // }

    ,
    {
      // 直连出口：局域网、保留地址等不走代理
      "type": "direct",
      "tag": "direct"
    }
  ],

  "route": {
    "rules": [
      {
        // 嗅探域名/协议，便于后续分流与 DNS 接管
        "action": "sniff"
      },
      {
        // 把 DNS 请求劫持给 sing-box 内部 DNS
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        // 私网地址不走代理
        "ip_is_private": true,
        "outbound": "direct"
      }
    ],

    // 默认所有流量走当前启用的代理出站
    "final": "proxy",

    // 自动检测真实出口网卡，避免 TUN 套娃
    "auto_detect_interface": true,

    // 默认域名解析器
    "default_domain_resolver": "local"
  }
}
