{
  "log": {
    "level": "info"
  },
  "inbounds": [
    {
      "type": "trojan",
      "tag": "trojan-in",
      "listen": "::",
      "listen_port": 443,
      "users": [
        {
          "name": "trojan-user",
          "password": "your-trojan-password"
        }
      ],
      "tls": {
        "enabled": true,
        "server_name": "your.domain.com",
        "certificate_path": "/etc/ssl/private/fullchain.pem",
        "key_path": "/etc/ssl/private/privkey.pem"
      }
    },
    {
      "type": "shadowsocks",
      "tag": "ss-in",
      "listen": "::",
      "listen_port": 8388,
      "method": "aes-256-gcm",
      "password": "your-ss-password"
    },
    {
      "type": "vmess",
      "tag": "vmess-in",
      "listen": "::",
      "listen_port": 9443,
      "users": [
        {
          "name": "vmess-user",
          "uuid": "11111111-1111-1111-1111-111111111111",
          "alterId": 0
        }
      ],
      "tls": {
        "enabled": true,
        "server_name": "your.domain.com",
        "certificate_path": "/etc/ssl/private/fullchain.pem",
        "key_path": "/etc/ssl/private/privkey.pem"
      }
    },
    {
      "type": "vless",
      "tag": "vless-in",
      "listen": "::",
      "listen_port": 8443,
      "users": [
        {
          "name": "vless-user",
          "uuid": "22222222-2222-2222-2222-222222222222"
        }
      ],
      "tls": {
        "enabled": true,
        "server_name": "your.domain.com",
        "certificate_path": "/etc/ssl/private/fullchain.pem",
        "key_path": "/etc/ssl/private/privkey.pem"
      }
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "final": "direct",
    "auto_detect_interface": true
  }
}



