<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>io.sagernet.sing-box</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/edy/go/bin/sing-box</string>
        <string>run</string>
        <string>-c</string>
        <string>/Users/edy/config/sing-box/config.json</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>WorkingDirectory</key>
    <string>/Users/edy/config/sing-box</string>
    <key>StandardOutPath</key>
    <string>/var/log/sing-box.log</string>
    <key>StandardErrorPath</key>
    <string>/var/log/sing-box.error.log</string>
</dict>
</plist>




<!-- 
xml: /Library/LaunchDaemons/io.sagernet.sing-box.plist
程序路径	/Users/edy/go/bin/sing-box   必须绝对路径
配置文件	/Users/edy/github/sing-box/cmd/sing-box/conf/config.json
开机启动	✅ RunAtLoad = true
保持运行	✅ KeepAlive = true
工作目录	/Users/edy/github/sing-box/cmd/sing-box/conf  不能设置tmp
标准输出日志	/var/log/sing-box.log
错误日志	/var/log/sing-box.error.log 

停止
launchctl unload /Library/LaunchDaemons/io.sagernet.sing-box.plist

启动
launchctl load /Library/LaunchDaemons/io.sagernet.sing-box.plist
-->